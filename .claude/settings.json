{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(./gradlew:*)",
      "Bash(git pull:*)",
      "Bash(ls:*)",
      "Bash(xargs grep:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ],
    "deny": [
      "Write(**/detekt.yml)"
    ],
    "additionalDirectories": [
      "~/.gradle"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
